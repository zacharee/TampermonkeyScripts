{
  "name": "vimeo-video-fit",
  "description": "Makes the Vimeo video player bigger.",
  "version": "0.0.1",
  "match": ["https://*.vimeo.com/*"],
  "author": {
    "name": "Zachary Wander",
    "email": "zachary@zwander.dev",
    "website": "https://zwander.dev"
  },
  "scripts": {
    "format": "prettier -w ./",
    "analize": "cross-env npm_config_report=true npm run build",
    "build": "webpack --config config/webpack.config.prod.cjs",
    "dev": "webpack --config config/webpack.config.dev.cjs",
    "prepare": "husky install",
    "lint-staged": "lint-staged"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zacharee/TampermonkeyScripts/"
  },
  "private": true,
  "dependencies": {
    "arrive": "^2.5.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "prettier --ignore-path ../.prettierignore --write "
    ]
  },
  "devDependencies": {
    "@types/arrive": "^2.4.4",
    "@types/greasemonkey": "^4.0.7",
    "@types/jquery": "^4.0.0",
    "@types/node": "^22.17.0",
    "browserslist": "^4.28.2",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "husky": "^9.1.7",
    "less": "^4.6.4",
    "less-loader": "^12.3.2",
    "lint-staged": "^16.4.0",
    "minimizer-webpack-plugin": "^5.6.1",
    "prettier": "^3.8.3",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "userscript-metadata-webpack-plugin": "^0.4.2",
    "webpack": "^5.106.2",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^7.0.2",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-merge": "^6.0.1",
    "webpack-node-externals": "^3.0.0",
    "webpack-sources": "^3.4.1"
  }
}
